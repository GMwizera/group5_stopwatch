<Window x:Class="StopwatchApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stopwatch" Height="195" Width="463">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TimerDisplay"
                   Grid.Row="0"
                   Text="00:00:00"
                   FontSize="36"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10" />

        <TextBlock x:Name="StatusLabel"
                   Grid.Row="1"
                   Text="Ready"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10" />

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,10,0,0">
            <Button x:Name="StartButton"  Content="Start"  Width="60" Margin="5" Click="StartButton_Click" />
            <Button x:Name="PauseButton"  Content="Pause"  Width="60" Margin="5" Click="PauseButton_Click" />
            <Button x:Name="ResumeButton" Content="Resume" Width="60" Margin="5" Click="ResumeButton_Click" />
            <Button x:Name="ResetButton"  Content="Reset"  Width="60" Margin="5" Click="ResetButton_Click" />
            <Button x:Name="StopButton"   Content="Stop"   Width="60" Margin="5" Click="StopButton_Click" />
        </StackPanel>
    </Grid>
</Window>